{
  "name": "notebooklm-mcp",
  "version": "1.0.0",
  "description": "MCP server para consultar y gestionar fuentes de Google NotebookLM desde cualquier CLI agéntico",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "notebooklm-mcp": "dist/server.js"
  },
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "inspect": "npx @modelcontextprotocol/inspector tsx src/server.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.9.1",
    "chokidar": "^4.0.3",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.15.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
